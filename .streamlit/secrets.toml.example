# Streamlit Cloud 密钥示例
# ===========================
# 部署时不要提交真正的 secrets.toml（已被 .gitignore 挡住）。
# 在 Streamlit Cloud 的 App settings -> Secrets 里粘贴下面的内容并填上真实值。
# 本地开发也可复制此文件为 .streamlit/secrets.toml 使用。

LLM_API_KEY = "你的key"
LLM_BASE_URL = "https://dashscope.aliyuncs.com/compatible-mode/v1"  # 千问示例；OpenAI 可删掉这行
LLM_MODEL = "qwen-plus"                                             # 千问示例
